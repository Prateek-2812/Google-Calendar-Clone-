    "outDir": "./dist",
    "noEmit": true,
    "paths": {
      "@calendar/shared": ["../shared/src/index.ts"]
    }
  },
  "include": ["src/**/*", "../shared/src/**/*"],
  "exclude": ["node_modules", "dist"]
}
