{
  "name": "@calendar/backend",
  "version": "1.0.0",
  "description": "Express + TypeScript backend for the Google Calendar Clone",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "db:migrate": "tsx src/db/migrations.ts"
  },
  "dependencies": {
    "@calendar/shared": "*",
    "better-sqlite3": "^11.10.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.16.1",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
